{
  "name": "@rwa-tokenized-compliance-system/evm",
  "version": "0.1.0",
  "private": true,
  "description": "Foundry contracts for regulated RWA security tokens — legacy registry and ERC-3643 / T-REX.",
  "scripts": {
    "build": "forge build",
    "test": "forge test -vvv",
    "test:unit": "forge test --match-path \"test/unit/*.t.sol\" -vvv",
    "test:security": "forge test --match-path \"test/security/*.t.sol\" -vvv",
    "coverage": "forge coverage --ir-minimum --report summary",
    "lint": "solhint \"src/**/*.sol\"",
    "slither": "slither . --config-file slither.config.json",
    "deploy:tenant": "mkdir -p deployments && forge script script/deploy/DeployTenantTrex.s.sol:DeployTenantTrex --rpc-url ${RPC_URL} --broadcast",
    "check:tooling": "bash scripts/check-tooling.sh",
    "local:fresh": "bash scripts/local-fresh.sh",
    "local:up": "bash scripts/run-local.sh",
    "local:down": "bash scripts/stop-local.sh",
    "deploy:local": "bash scripts/deploy-local.sh",
    "deploy:sepolia": "bash scripts/deploy-sepolia.sh",
    "deploy:sepolia:legacy": "bash scripts/deploy-sepolia-legacy.sh"
  },
  "dependencies": {
    "@openzeppelin/contracts": "5.6.1",
    "@openzeppelin/contracts-upgradeable": "^5.6.1"
  },
  "devDependencies": {
    "solhint": "^6.0.0"
  }
}
