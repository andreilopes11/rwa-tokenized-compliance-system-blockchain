{
  "name": "@rwa-tokenized-compliance-system/evm",
  "version": "0.1.0",
  "private": true,
  "description": "Foundry contracts for the RWA tokenized compliance MVP.",
  "scripts": {
    "build": "forge build",
    "test": "forge test -vvv",
    "test:unit": "forge test --match-path \"test/unit/*.t.sol\" -vvv",
    "check:tooling": "bash scripts/check-tooling.sh",
    "local:fresh": "bash scripts/local-fresh.sh",
    "local:up": "bash scripts/run-local.sh",
    "local:down": "bash scripts/stop-local.sh",
    "deploy:local": "bash scripts/deploy-local.sh",
    "deploy:sepolia": "mkdir -p deployments && forge script script/deploy/DeployCore.s.sol:DeployCore --rpc-url ${SEPOLIA_RPC_URL} --broadcast --verify"
  },
  "dependencies": {
    "@openzeppelin/contracts": "5.6.1"
  }
}
